# Azure Data Box Configuration
# Configure Data Box for staging Oracle CSV exports
# Author: DBRE Team

# ============================================================================
# DATA BOX DEVICE DETAILS
# ============================================================================

# Data Box device name and serial number (provided by Azure)
DATABOX_DEVICE_NAME="DB-DataBox-001"
DATABOX_SERIAL_NUMBER="123456789ABC"
DATABOX_CAPACITY_TB=1

# Data Box access IP and credentials
DATABOX_IP_ADDRESS="192.168.1.100"
DATABOX_USERNAME="databox_admin"
DATABOX_PASSWORD="<secure-password>"

# NFS share for mounting Data Box on extraction host
DATABOX_NFS_SHARE="/mnt/databox/csv"
DATABOX_NFS_MOUNT_OPTIONS="vers=4.1,rsize=65536,wsize=65536,hard,timeo=600,retrans=2"

# ============================================================================
# ORACLE EXPORT TO DATA BOX
# ============================================================================

# Directory on extraction host for staged CSV files (before Data Box transfer)
ORACLE_EXPORT_STAGING="/data/oracle_exports"

# Parallel export degree (expdp parallel processes)
ORACLE_EXPORT_PARALLEL=8

# CSV chunk size (rows per file)
ORACLE_EXPORT_CHUNK_SIZE=100000

# Compression on export (Y/N)
ORACLE_EXPORT_COMPRESS="Y"

# Tables to export (comma-separated; leave empty for ALL)
ORACLE_EXPORT_TABLES=""

# Exclude system tables (Y/N)
ORACLE_EXCLUDE_SYSTEM="Y"

# ============================================================================
# DATA BOX TO AZURE ADLS TRANSFER
# ============================================================================

# Azure subscription and resource group
AZURE_SUBSCRIPTION_ID="12345678-1234-1234-1234-123456789abc"
AZURE_RESOURCE_GROUP="rg-migration-prod"
AZURE_REGION="eastus"

# Azure Storage account (Data Lake Storage Gen2)
AZURE_STORAGE_ACCOUNT="migrationadls01"
AZURE_STORAGE_ACCOUNT_KEY="<account-key>"
AZURE_STORAGE_CONTAINER="oracle-migration"

# ADLS paths
ADLS_RAW_CSV_PATH="/raw/csv"
ADLS_PROCESSED_PARQUET_PATH="/processed/parquet"
ADLS_ARCHIVE_PATH="/archive"

# Data Box resource group (different from migration resources)
DATABOX_RESOURCE_GROUP="rg-databox"

# ============================================================================
# DATA BOX SCHEDULING
# ============================================================================

# Estimated shipment date (from Azure)
DATABOX_SHIP_DATE="2026-05-15"
DATABOX_EXPECTED_ARRIVAL="2026-05-20"
DATABOX_EXPECTED_RETURN_DATE="2026-06-20"

# Tracking number (assigned by carrier)
DATABOX_TRACKING_NUMBER="1Z999AA10123456784"

# Contact information
DATABOX_CONTACT_NAME="John Smith"
DATABOX_CONTACT_PHONE="+1-425-555-0123"
DATABOX_CONTACT_EMAIL="john.smith@company.com"

# Delivery address (Azure datacenter)
DATABOX_DELIVERY_ADDRESS="Microsoft Azure Datacenter, 100 Main St, Redmond, WA 98052"

# ============================================================================
# VALIDATION & CHECKSUMS
# ============================================================================

# Generate MD5 checksums during export (Y/N)
DATABOX_GENERATE_CHECKSUMS="Y"

# Verify checksums post-transfer to ADLS (Y/N)
DATABOX_VERIFY_CHECKSUMS="Y"

# Retention period for CSV files after Parquet conversion (days)
CSV_RETENTION_DAYS=7

# Archive CSV to cold storage after retention (Y/N)
CSV_ARCHIVE_COLD_STORAGE="Y"

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Enable verbose logging for Data Box transfer
DATABOX_VERBOSE_LOGGING="Y"

# Log file path
DATABOX_LOG_FILE="/var/log/databox_migration.log"

# Alert email on transfer completion
ALERT_EMAIL="dba-team@company.com"

# Alert on errors (Y/N)
ALERT_ON_ERROR="Y"

# ============================================================================
# RETRY & FAILOVER
# ============================================================================

# Max retries for failed transfers
MAX_RETRIES=3

# Retry interval (seconds)
RETRY_INTERVAL=300

# Alternative export method if Data Box fails (DIRECT/NETWORK_COPY/ADF)
FALLBACK_TRANSFER_METHOD="NETWORK_COPY"

# Fallback network bandwidth limit (Mbps; 0 = unlimited)
FALLBACK_NETWORK_LIMIT_MBPS=1000

# ============================================================================
# POST-TRANSFER VALIDATION
# ============================================================================

# List of expected CSV files (sanity check)
EXPECTED_CSV_FILES="
customers.csv
orders.csv
order_items.csv
products.csv
"

# Total expected rows across all tables
EXPECTED_TOTAL_ROWS=500000000

# Expected CSV total size (GB)
EXPECTED_CSV_SIZE_GB=800

# ============================================================================
# NOTES
# ============================================================================
# 1. Update all <values> before Data Box preparation
# 2. Test NFS connectivity before scheduling Data Box shipment
# 3. Verify checksums against Oracle export manifest
# 4. Monitor ADLS ingestion progress in Azure Portal
# 5. Confirm all CSV files available in ADLS before starting Parquet conversion
